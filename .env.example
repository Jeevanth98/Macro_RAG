# .env.example
# Rename this file to .env and fill in your details.

# FRED API Key (Required for fred_loader.py)
# Get a free key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY="YOUR_FRED_API_KEY"

# --- Local Service Configuration ---
# These are the default values. Change them only if your setup is different.

# Gemini API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash"

# Neo4j credentials (must match docker-compose.yml)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

# ChromaDB path (local filesystem)
CHROMA_PATH="./data/chroma_db"
